{
  "name": "angular-isr",
  "version": "0.1.0",
  "description": "Incremental Static Regeneration (ISR) for Angular SSR applications with multitenancy, CMS webhooks, and hybrid rendering",
  "author": "Ibrahim Salama <ibrahimSalama100@outlook.com>",
  "repository": { "type": "git", "url": "https://github.com/IbrahimSalama01/angular-isr.git" },
  "homepage": "https://github.com/IbrahimSalama01/angular-isr#readme",
  "keywords": ["angular", "ssr", "isr", "incremental-static-regeneration", "caching", "angular-ssr"],
  "bugs":{
    "url": "https://github.com/IbrahimSalama01/angular-isr/issues"
  },
  "license": "MIT",
  "engines": { "node": ">=18" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "server": ["./dist/server.d.ts"],
      "adapters/express": ["./dist/adapters/express.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@angular/common": ">=17",
    "@angular/core": ">=17",
    "@angular/platform-browser": ">=17",
    "@angular/ssr": ">=17",
    "express": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@angular/common": { "optional": false },
    "@angular/core": { "optional": false },
    "@angular/platform-browser": { "optional": false },
    "@angular/ssr": { "optional": true },
    "express": { "optional": true }
  },
  "devDependencies": {
    "@angular/core": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-server": "^17.3.0",
    "@angular/ssr": "^17.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^18.19.0",
    "tsup": "^8.3.5",
    "typescript": "~5.4.0"
  }
}
